{
  "service": "PublicGeneral",
  "folder": "PublicGeneral",
  "steps": [
    {
      "method": "getBranches"
    },
    {
      "method": "getCountries",
      "extract": [
        {
          "path": "countries.country",
          "where": { "Name": "México" },
          "field": "Id",
          "as": "countryId"
        }
      ]
    },
    {
      "method": "getAdministrativeLevels",
      "extract": [
        {
          "path": "administrativeLevels.administrativeLevel[0].Id",
          "as": "administrativeLevelId"
        }
      ]
    },
    {
      "method": "getDocumentTypes",
      "extract": [
        {
          "path": "documentTypes.documentType[0].Id",
          "as": "documentTypeId"
        }
      ]
    },
    {
      "method": "getSystemDate"
    }
  ]
}