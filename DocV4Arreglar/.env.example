# ─── Base de datos Oracle (Bantotal V4) ───────────────────
# Requiere Oracle Instant Client instalado en el sistema
# Descarga: https://www.oracle.com/database/technologies/instant-client.html
DB_USER=usuario-oracle
DB_PASSWORD=contraseña-oracle

# Formato: ip-servidor:puerto/nombre-servicio
# Ejemplo: 10.0.0.4:1521/btv4db
DB_CONNECT_STRING=ip-servidor:1521/nombre-servicio

# ─── URL base para los links de documentacion ─────────────
# Ejemplo: https://miservidor-v4:8445
BASE_URL=https://tu-servidor-v4:puerto

# ─── API para ejecucion real (--ejecutar) ─────────────────
# URL base del core Bantotal V4
API_BASE_URL=http://ip-servidor:puerto/nombre-core

# Credenciales de usuario Bantotal para obtener token
API_USER=INSTALADOR
API_PASSWORD=tu-contraseña-api
