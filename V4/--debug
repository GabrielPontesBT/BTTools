{
  "service": "PublicSavingAccounts",
  "folder": "PublicSavingAccounts",
  "steps": [
    {
      "method": "getCancellationOrigins",
      "extract": [
        {
          "path": "cancellationOrigins.cancellationOrigin[0].id",
          "as": "cancellationOriginId"
        }
      ]
    },
    {
      "method": "getCancellationReasons",
      "extract": [
        {
          "path": "cancellationReasons.cancellationReason[0].id",
          "as": "cancellationReasonId"
        }
      ]
    },
    {
      "method": "getCustomerSavingsAccounts"
    },
    {
      "method": "getPersonProducts",
      "extract": [
        {
          "path": "products.product[0].ProductGUID",
          "as": "productGUID"
        }
      ]
    },
    {
      "method": "getProducts",
      "extract": [
        {
          "path": "products.product[0].ProductGUID",
          "as": "productGUID"
        }
      ]
    },
    {
      "method": "create",
      "extract": [
        "savingAccountGUID"
      ]
    },
    {
      "method": "block"
    },
    {
      "method": "cancel",
      "extract": [
        "movementGUID"
      ]
    },
    {
      "method": "getDetailedData"
    },
    {
      "method": "transfer",
      "extract": [
        "movementGUID"
      ]
    },
    {
      "method": "unblock"
    },
    {
      "method": "updateProduct"
    }
  ]
}