                  "}",
                  "var out_Customers_getTexts_texts_SdtsBTPAWText_item_Text = pick(data, [\"texts\",\"SdtsBTPAWText\",\"item\",\"Text\"]);",
                  "if (out_Customers_getTexts_texts_SdtsBTPAWText_item_Text !== undefined && out_Customers_getTexts_texts_SdtsBTPAWText_item_Text !== null && typeof out_Customers_getTexts_texts_SdtsBTPAWText_item_Text !== 'object') {",
