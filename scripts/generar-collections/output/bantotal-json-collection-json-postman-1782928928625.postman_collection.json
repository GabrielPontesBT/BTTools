                  "var data = {};",
                  "try { data = text ? JSON.parse(text) : {}; } catch (e) {}",
                  "function pick(node, parts) {",
                  "  if (node === null || node === undefined) return undefined;",
                  "  if (!parts.length) return node;",
                  "  var current = parts[0];",
                  "  var rest = parts.slice(1);",
                  "  if (Array.isArray(node)) {",
                  "    if (current === 'item') {",
                  "      for (var i = 0; i < node.length; i++) {",
                  "        var foundItem = pick(node[i], rest);",
                  "        if (foundItem !== undefined && foundItem !== null && foundItem !== '') return foundItem;",
                  "      }",
                  "      return undefined;",
                  "    }",
                  "    for (var j = 0; j < node.length; j++) {",
                  "      var foundArray = pick(node[j], parts);",
                  "      if (foundArray !== undefined && foundArray !== null && foundArray !== '') return foundArray;",
                  "    }",
                  "    return undefined;",
                  "  }",
                  "  if (typeof node !== 'object') return undefined;",
                  "  return pick(node[current], rest);",
                  "}",
                  "var out_Customers_getTexts_texts_SdtsBTPAWText_item_Description = pick(data, [\"texts\",\"SdtsBTPAWText\",\"item\",\"Description\"]);",
                  "if (out_Customers_getTexts_texts_SdtsBTPAWText_item_Description !== undefined && out_Customers_getTexts_texts_SdtsBTPAWText_item_Description !== null && typeof out_Customers_getTexts_texts_SdtsBTPAWText_item_Description !== 'object') {",
