# ─── Base de datos SQL Server (Bantotal V3) ───────────────
DB_SERVER=tu-servidor-sql
DB_PORT=1433
DB_DATABASE=nombre-base-de-datos
DB_USER=usuario-bd
DB_PASSWORD=contraseña-bd

# ─── URL base para los links de documentacion ─────────────
# Ejemplo: https://miservidor:6004
BASE_URL=https://tu-servidor:puerto

# ─── API para ejecucion real (--ejecutar) ─────────────────
# URL base del ambiente Bantotal
API_BASE_URL=https://tu-servidor:puerto/nombre-bd

# URL del servlet de autenticacion
API_AUTH_URL=https://tu-servidor:puerto/nombre-bd/servlet/com.dlya.bantotal.ardwsbt_Authenticate_v1

# Credenciales de usuario Bantotal para obtener token
API_USER=INSTALADOR
API_PASSWORD=tu-contraseña-api
